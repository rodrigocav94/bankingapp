    "We are experiencing delays in retrieving your statement. Please try again in a few minutes." : {
      "comment" : "Alert message displayed when an error occurs while loading transactions.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نواجه تأخيرًا في استرجاع كشف حسابك. يرجى المحاولة مرة أخرى بعد بضع دقائق."
